# ── Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FAST=gemini-2.0-flash

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./db/artha.db

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEMO_USER_ID=1
OTEL_ENABLED=false

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
